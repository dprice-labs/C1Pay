{
  "name": "c1pay",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration --passWithNoTests",
    "test:integration:docker": "docker compose -f docker-compose.integration.yml up -d --wait && DATABASE_URL=postgresql://postgres:postgres@localhost:5433/c1pay npm run db:migrate && DATABASE_URL=postgresql://postgres:postgres@localhost:5433/c1pay npm run test:integration; status=$?; docker compose -f docker-compose.integration.yml down >/dev/null 2>&1; exit $status",
    "test:e2e": "playwright test --pass-with-no-tests",
    "test:e2e:docker": "docker compose -f docker-compose.e2e.yml up --exit-code-from e2e; status=$?; docker compose -f docker-compose.e2e.yml down --remove-orphans >/dev/null 2>&1; exit $status",
    "test:e2e:docker:clean": "docker compose -f docker-compose.e2e.yml down -v --remove-orphans",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node src/db/migrate.mjs",
    "seed": "tsx --env-file-if-exists=.env.local scripts/seed.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.2.3",
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "jsdom": "^29.1.1",
    "shadcn": "^4.10.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  },
  "allowScripts": {
    "fsevents@2.3.2": true,
    "fsevents@2.3.3": true,
    "unrs-resolver@1.12.2": true,
    "esbuild@0.18.20": true,
    "esbuild@0.25.12": true,
    "esbuild@0.28.0": true,
    "msw@2.14.6": true,
    "sharp@0.34.5": true
  }
}
